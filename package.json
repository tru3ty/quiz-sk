{
  "name": "starquiz-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:generate": "bun --filter @starquiz/db db:generate",
    "db:migrate": "bun --filter @starquiz/db db:migrate",
    "db:studio": "bun --filter @starquiz/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  }
}
