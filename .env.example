# Neon PostgreSQL — прямое подключение (для drizzle-kit migrate/generate)
DATABASE_URL=postgresql://ROLE:PASSWORD@HOST/DATABASE?sslmode=require

# Neon PostgreSQL — pooler подключение (для serverless API)
DATABASE_URL_POOL=postgresql://ROLE:PASSWORD@POOLER_HOST/DATABASE?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3001
